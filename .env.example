# ─── Contact Form (Google Forms bridge) ─────────────────────────────────────
# See app/api/contact/route.ts for usage

GOOGLE_FORM_LINK=your_gform_prefilled_link
GOOGLE_FORM_FIELD_ID_NAME=entry_field_id_gform
GOOGLE_FORM_FIELD_ID_EMAIL=entry_field_id_gform
GOOGLE_FORM_FIELD_ID_MESSAGE=entry_field_id_gform
GOOGLE_FORM_FIELD_ID_SOCIAL=entry_field_id_gform

# Google Analytics
NEXT_PUBLIC_GOOGLE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Visitor Notifications (ntfy.sh) ─────────────────────────────────────────
# Server-side only (no NEXT_PUBLIC prefix — never exposed to the browser)
# Subscribe to each topic in the ntfy Android/iOS app.
# NTFY_BOT_TOPIC: subscribe with notifications silenced (history only).
NTFY_TOPIC=your_ntfy_visitor_topic
NTFY_BOT_TOPIC=your_ntfy_bot_topic

# ─── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id

# ─── Company Logos (logo.dev) ─────────────────────────────────────────────────
# Used in experience cards — get a token at logo.dev
NEXT_PUBLIC_LOGODEV_TOKEN=your_logodev_token

# ─── Resume / Upwork redirect ─────────────────────────────────────────────────
# /resume redirects to this URL
NEXT_PUBLIC_RESUME_LINK=your_resume_or_upwork_link

# ─── Google Search Console ────────────────────────────────────────────────────
# Only needed if verifying via HTML meta tag (not required if using DNS TXT record)
# NEXT_PUBLIC_GOOGLE_VERIFICATION=your_verification_token
